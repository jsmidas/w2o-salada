# ── 데이터베이스 ──
DATABASE_URL="postgresql://user:password@localhost:5432/w2o_salada"

# ── NextAuth ──
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# ── 소셜 로그인 ──
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# ── 토스페이먼츠 ──
TOSS_CLIENT_KEY=""
TOSS_SECRET_KEY=""

# ── 알림톡 (NHN Cloud) ──
NHN_APP_KEY=""
NHN_SECRET_KEY=""
NHN_SENDER_KEY=""

# ── 빌링키 암호화 (필수) ──
# AES-256-GCM용 32바이트 hex 키. 분실 시 기존 암호화 빌링키 복호화 불가 → 고객 재등록 필요
# 생성: `openssl rand -hex 32`
BILLING_ENCRYPTION_KEY=""

# ── Redis ──
REDIS_URL="redis://localhost:6379"

# ── Sentry 에러 모니터링 (선택: 비워두면 비활성화) ──
# Sentry 프로젝트 생성 후 DSN 복사. prod/preview에만 넣으면 됨.
NEXT_PUBLIC_SENTRY_DSN=""
# 소스맵 업로드용 (선택, 없으면 스택트레이스가 난독화됨)
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
