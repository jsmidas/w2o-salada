generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── 회원 ──
model User {
  id            String    @id @default(cuid())
  username      String?   @unique
  email         String    @unique
  password      String?
  name          String
  phone         String?
  role          Role      @default(CUSTOMER)
  permissions   String?   // JSON: ["dashboard","orders","products","subscriptions","customers","system"] — null = 슈퍼관리자(전체권한)
  provider      String?   // kakao, naver, email
  providerId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addresses     Address[]
  orders        Order[]
  subscriptions Subscription[]
  notifications Notification[]
  reviews       Review[]

  @@map("users")
}

enum Role {
  CUSTOMER
  ADMIN
  DRIVER
}

// ── 배송지 ──
model Address {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id])
  name         String  // 수령인
  phone        String
  zipCode      String
  address1     String  // 기본 주소
  address2     String? // 상세 주소
  isDefault    Boolean @default(false)
  deliveryMemo String?

  orders Order[]

  @@map("addresses")
}

// ── 카테고리 ──
model Category {
  id       String    @id @default(cuid())
  name     String    // 샐러드, 간편식, 반찬 등
  slug     String    @unique
  sortOrder Int      @default(0)
  icon     String?   // material-symbols 아이콘 이름 (예: eco, lunch_dining)
  color    String?   // hex 색상 (예: #1D9E75)
  isActive Boolean   @default(true) // 공개 여부
  isOption Boolean   @default(false) // true면 본품 아님 (최소 주문액 계산 제외) — 음료/유산균 등
  products Product[]

  @@map("categories")
}

// ── 상품 (메뉴) ──
model Product {
  id          String   @id @default(cuid())
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  name        String
  description String?
  originalPrice Int?     // 정가 (원)
  singlePrice Int?       // 단건 주문가 (원) — 없으면 price 사용. 정가 > 단건가 > 구독가 3-티어 모델의 중간 값
  price       Int      // 구독 판매가 (원, 부가세 포함) — 구독 시 적용
  nextPrice              Int?      // 예약 인상가 — nextPriceEffectiveFrom 도래 시 price로 자동 승격
  nextPriceEffectiveFrom DateTime? // 예약 인상 적용일 (KST 자정)
  kcal        Int?
  imageUrl    String?
  tags        String?  // "BEST", "NEW", "SALE" 등
  isActive    Boolean  @default(true)
  stock       Int      @default(999)
  dailyLimit  Int?     // 일일 제한 수량 (null=무제한)
  availableDays String? // 배송 가능 요일 "월,수,금" 또는 null=매일
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems              OrderItem[]
  subscriptionItems       SubscriptionItem[]
  menuSchedules           MenuSchedule[]
  menuAssignments         MenuAssignment[]
  subscriptionSelections  SubscriptionSelection[]
  reviews                 Review[]

  @@index([categoryId, isActive, sortOrder])
  @@map("products")
}

// ── 주문 ──
model Order {
  id              String      @id @default(cuid())
  orderNo         String      @unique // W2O-20260401-0001
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  addressId       String?
  address         Address?    @relation(fields: [addressId], references: [id])
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  type            OrderType   @default(SINGLE)
  status          OrderStatus @default(PENDING)
  totalAmount     Int         // 총 결제 금액
  deliveryFee     Int         @default(0)
  discountAmount  Int         @default(0)
  paymentKey      String?     // 토스 paymentKey
  paidAt          DateTime?
  deliveryDate    DateTime?   // 배송 예정일
  deliveredAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items     OrderItem[]
  payments  Payment[]
  delivery  Delivery?

  @@map("orders")
}

enum OrderType {
  SINGLE
  SUBSCRIPTION
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  SHIPPING
  DELIVERED
  CANCELLED
  REFUNDED
  FAILED
}

// ── 주문 상품 ──
model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id])
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  quantity   Int
  unitPrice  Int
  totalPrice Int

  @@map("order_items")
}

// ── 결제 ──
model Payment {
  id           String        @id @default(cuid())
  orderId      String
  order        Order         @relation(fields: [orderId], references: [id])
  paymentKey   String?       // 토스 paymentKey
  method       String?       // CARD, KAKAOPAY, NAVERPAY
  amount       Int
  status       PaymentStatus @default(READY)
  billingKey   String?       // 정기결제용 (암호화)
  receiptUrl   String?
  cancelReason String?
  cancelledAt  DateTime?
  rawResponse  String?       // 토스 원본 응답 (JSON 문자열)
  createdAt    DateTime      @default(now())

  @@map("payments")
}

enum PaymentStatus {
  READY
  DONE
  CANCELLED
  REFUNDED
  FAILED
}

// ── 정기구독 ──
model Subscription {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  planType          PlanType?          // deprecated, optional로 유지
  frequency         Frequency?         // deprecated, optional로 유지
  selectionMode     SelectionMode      @default(MANUAL)
  itemsPerDelivery  Int                @default(2)  // 배송당 수량 (슬롯 합과 동기화)
  slots             Json?              // 카테고리별 슬롯 { "salad": 2, "simple": 1, ... } — key=Category.slug
  status            SubscriptionStatus @default(PENDING)
  billingKey        String?            // 토스 빌링키 (암호화)
  nextBillingDate   DateTime?
  nextDeliveryDate  DateTime?
  renewalNotifiedAt DateTime?          // 갱신 사전 알림 발송일
  price             Int
  startedAt         DateTime?
  pausedAt          DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  items   SubscriptionItem[]
  periods SubscriptionPeriod[]
  orders  Order[]

  @@map("subscriptions")
}

enum SelectionMode {
  MANUAL  // 고객 직접 선택
  AUTO    // 잘 챙겨서 보내줘 (위임형)
}

enum PlanType {
  LIGHT
  REGULAR
  PREMIUM
}

enum Frequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAUSED
  CANCELLED
}

// ── 구독 메뉴 구성 ──
model SubscriptionItem {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  productId      String
  product        Product      @relation(fields: [productId], references: [id])
  quantity       Int          @default(1)
  dayOfWeek      Int?         // 0=일, 1=월 ~ 6=토

  @@map("subscription_items")
}

// ── 배송 ──
model Delivery {
  id            String         @id @default(cuid())
  orderId       String         @unique
  order         Order          @relation(fields: [orderId], references: [id])
  driverId      String?
  status        DeliveryStatus @default(PENDING)
  scheduledDate DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  photoUrl      String?        // 배송 확인 사진
  memo          String?
  sortOrder     Int            @default(0) // 배송 코스 순서

  @@map("deliveries")
}

enum DeliveryStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  FAILED
}

// ── 알림 ──
model Notification {
  id           String             @id @default(cuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id])
  type         NotificationType
  templateCode String?
  content      String
  sentAt       DateTime?
  status       NotificationStatus @default(PENDING)
  createdAt    DateTime           @default(now())

  @@map("notifications")
}

enum NotificationType {
  ALIMTALK
  SMS
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// ── 상품 상세페이지 ──
model ProductPage {
  id                 String   @id @default(cuid())
  productId          String   @unique
  heroImages         String?  // JSON: ["url1","url2"]
  subtitle           String?
  featureTitle       String?
  featureDescription String?
  featureImages      String?  // JSON: ["url1"]
  keyPoints          String?  // JSON: [{icon,title,description}]
  specs              String?  // JSON: [{label,value}]
  detailDescription  String?
  detailImages       String?  // JSON: ["url1"]
  nutrition          String?  // JSON: [{label,value}]
  galleryImages      String?  // JSON: ["url1"]
  sectionOrder       String?  // JSON: ["hero","feature","keypoints",...]
  isPublished        Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("product_pages")
}

// ── 배송일 캘린더 (관리자 지정) ──
model DeliveryCalendar {
  id        String   @id @default(cuid())
  date      DateTime @unique
  isActive  Boolean  @default(true)
  memo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menuAssignments MenuAssignment[]

  @@map("delivery_calendar")
}

// ── 날짜별 제공 메뉴 (관리자 배정) ──
model MenuAssignment {
  id                 String           @id @default(cuid())
  deliveryCalendarId String
  deliveryCalendar   DeliveryCalendar @relation(fields: [deliveryCalendarId], references: [id], onDelete: Cascade)
  productId          String
  product            Product          @relation(fields: [productId], references: [id])
  sortOrder          Int              @default(0)
  createdAt          DateTime         @default(now())

  @@unique([deliveryCalendarId, productId])
  @@map("menu_assignments")
}

// ── 월별 구독 사이클 ──
model SubscriptionPeriod {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  year           Int
  month          Int
  status         PeriodStatus @default(PENDING)
  totalAmount    Int          @default(0)
  orderId        String?
  paidAt         DateTime?
  createdAt      DateTime     @default(now())

  selections SubscriptionSelection[]

  @@unique([subscriptionId, year, month])
  @@map("subscription_periods")
}

enum PeriodStatus {
  PENDING
  PAID
  DELIVERING
  COMPLETED
  CANCELLED
}

// ── 고객 날짜별 메뉴 선택 ──
model SubscriptionSelection {
  id                   String             @id @default(cuid())
  subscriptionPeriodId String
  subscriptionPeriod   SubscriptionPeriod @relation(fields: [subscriptionPeriodId], references: [id], onDelete: Cascade)
  deliveryDate         DateTime
  productId            String
  product              Product            @relation(fields: [productId], references: [id])
  quantity             Int                @default(1)
  unitPrice            Int?               // 결제 시점 단가 잠금 (계약가) — null이면 product.price fallback

  @@map("subscription_selections")
}

// ── 식단 배정 (레거시, deprecated) ──
model MenuSchedule {
  id        String @id @default(cuid())
  year      Int    // 2026
  month     Int    // 1~12
  week      Int    // 1~4 (해당 월의 주차)
  day       String // "tue" | "thu"
  slot      Int    // 슬롯 순서 (0, 1, 2 ...)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month, week, day, slot])
  @@map("menu_schedules")
}

// ── 리뷰 ──
model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  orderId   String?  // 주문 연결 (선택)
  rating    Int      // 1~5
  content   String
  images    String?  // JSON array of image URLs
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reviews")
}

// ── 쇼핑몰 설정 (key-value) ──
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}
